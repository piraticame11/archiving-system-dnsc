# Server
PORT=3000
NODE_ENV=development

# Database (MySQL — must be running locally or on your server)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=archiving_system
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT
JWT_SECRET=replace_with_64+_random_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_64+_random_chars
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer — Gmail example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=yourapp@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="ACES Research Office <yourapp@gmail.com>"

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:3000

# Superadmin seed (used by npm run migrate)
SUPERADMIN_EMAIL=superadmin@aces.edu.ph
SUPERADMIN_PASSWORD=Admin@1234
